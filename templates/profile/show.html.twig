{# Roman #}
{% extends 'base.html.twig' %}

{% block title %}Profile - {{ user.firstname }} {{ user.lastname }}
{% endblock %}

{% block body %}

    <div class="profile-wrapper">
        <div class="profile-card">
            {% if user.picture %}
                <img src="{{ asset('images/profilePictures/' ~ user.picture) }}"
                alt="Photo of {{ user.firstname }}"
                class="profile-avatar" />
            {% else %}
                <div class="profile-avatar-placeholder">👤</div>
            {% endif %}

            <h1 class="profile-name">{{ user.firstname ~ ' ' ~ user.lastname }}</h1>
            <p class="profile-username">@{{ user.username }}</p>

            <div class="profile-info">

                <div class="info-row">
                    <span class="info-label">Email</span>
                    <span class="info-value">{{ user.email }}</span>
                </div>

                <div class="info-row">
                    <span class="info-label">Telephone</span>
                    <span class="info-value">{{ user.phoneNumber}}</span>
                </div>

                <div class="info-row">
                    <span class="info-label">Campus</span>
                    <span class="info-value">{{ user.campus ? user.campus.name : 'Not defined' }}</span>
                </div>

                <div class="info-row">
                    <span class="info-label">Status</span>
                    <span class="info-value {{ user.active ? 'badge-active' : 'badge-inactive' }}">{{ user.active ? 'Actif' : 'Inactif'}}</span>
                </div>
            </div>

            {% if app.user == user %}
                <a href="{{ path('app_profile_edit', {id: user.id}) }}" class="btn-edit">Modifier mon profil</a>
            {% endif %}
            <a href="{{ path('home') }}" class="btn-back">Retour</a>

        </div>
    </div>
{% endblock %}




