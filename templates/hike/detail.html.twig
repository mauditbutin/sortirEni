{% extends 'base.html.twig' %}

{#+++++++++++++++ BLOCK MAP +++++++++++++++++#}

{% block stylesheets %}
    {{ parent() }}
    <link
        rel="stylesheet"
        href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    />
    <style>
        /* Стили карты и кнопок переключения */
        #map {
            height: 420px;
            width: 100%;
            border-radius: 8px;
            margin-top: 1rem;
        }
        .map-controls {
            display: flex;
            gap: 8px;
            margin-bottom: 8px;
            flex-wrap: wrap;
        }
        .map-controls button {
            padding: 6px 14px;
            border: 2px solid #ccc;
            border-radius: 6px;
            background: white;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.2s;
        }
        .map-controls button:hover {
            border-color: #4a7c59;
            background: #f0f7f2;
        }
        .map-controls button.active {
            border-color: #4a7c59;
            background: #4a7c59;
            color: white;
        }
    </style>
{% endblock %}



{% block body %}
    <div>
        <h2>{{ hike.name }}</h2>
        <div>
            <div>
                <img
                    src="{{ asset('images/hikes/' ~ hike.picture ) }}"
                    alt="{{ hike.name }}" style="width: 10rem">
            </div>
            <div>
                Description : {{ hike.description }} <br>
                Organisateur
                : {% if hike.planner %}{{ hike.planner.username }}{% else %} utilisateur supprimé {% endif %}
                <br>
                Date de l'évènement : {{ hike.dateEvent | date ('d-m-Y') }}<br>
                Date limite d'inscription : {{ hike.dateSubscription | date ('d-m-Y') }}<br>
                Statut : {{ hike.status.label }}<br>
                Difficulté : {{ hike.difficulty.label }}<br>
                Durée estimée : {{ durationString }}<br>
                Nombre de participants : {{ hike.participant|length }} / {{ hike.nbMaxSubscription }}<br>

                participants : <br>{% for participant in hike.participant %} <a
                href="{{ path('app_profile', {'id': participant.id}) }}"><img
                    src="{{ asset('images/profilePictures/' ~ participant.picture) }}"
                    alt="{{ participant.username }}" style="width: 5rem"> {{ participant.username }}</a><br>{% endfor %}

                Point de rendez-vous : {{ hike.location.name }}<br>
                Campus de rattachement : {{ hike.campus.name }}<br>
            </div>
        </div>
{#++++++++++++++ BLOCK MAP ++++++++++++++++#}
        {% if hike.location.latitude and hike.location.longitude %}

            {# button of style #}
            <div class="map-controls">
                <strong style="line-height: 2;">Style :</strong>
                <button class="active" onclick="setLayer('streets', this)">🗺️ Plan</button>
                <button onclick="setLayer('satellite', this)">🛰️ Satellite</button>
                <button onclick="setLayer('terrain', this)">🏔️ Relief</button>
            </div>


            <div id="map"></div>

        {% else %}

            <p style="color: gray; font-style: italic; margin-top: 1rem;">
                📍 Aucune coordonnée disponible pour afficher la carte.
            </p>
        {% endif %}



        {% if user == hike.planner or is_granted('ROLE_ADMIN') %}
            <button><a href="{{ path('hike_edit', {'id': hike.id}) }}">Modifier la randonnée</a></button>
            {% if hike.status.label == 'Ouverte' or hike.status.label == 'Clôturée' or is_granted('ROLE_ADMIN') %}
                <a href="#modalCancel" id="buttonOpenLocationModale">
                    <button id="buttonHikeCancel"> Annuler la randonnée</button>
                </a>
            {% endif %}
            {% if hike.status.label == 'Créée' or is_granted('ROLE_ADMIN') %}
                <a href="{{ path('hike_publish', {'id': hike.id}) }}">
                    <button>Publier la randonnée</button>
                </a>
                <a href="{{ path('hike_delete', {'id': hike.id}) }}">
                    <button> Supprimer</button>
                </a>
            {% endif %}
        {% elseif hike.participant.contains(user) %}
            <a href="{{ path('hike_unsubscribe', {'id': hike.id}) }}">
                <button> Se désinscrire</button>
            </a>
        {% else %}
            {% if hike.status.label != 'Créée' %}
                <a href="{{ path('hike_subscribe', {'id': hike.id}) }}">
                    <button> S'inscrire</button>
                </a>
            {% endif %}
        {% endif %}


    </div>

    <div id="modalCancel" class="modale">
        <a href="#" class="modaleOverlay" id="modaleCancelOverlay"></a>
        <div class="modaleContent modale-form-cancel">
            <p>Motif d'annulation de la randonnée : </p>
            {% form_theme formCancel 'views/form-theme.html.twig' %}
            {{ form_start(formCancel, {'action': path('hike_cancel', {'id': hike.id}), 'method': 'POST'}) }}
            {{ form_row(formCancel.description, {label: 'Description', label_attr: {class: 'visually-hidden'}}) }}
            <div class="form-row form-buttons">
                <button type="submit" class="form-col form-button-submit">Confirmer l'annulation</button>
                <button id="buttonCancelModale" class="form-col form-button-cancel">Retour</button>
            </div>
            {{ form_end(formCancel) }}
        </div>

    </div>


    {#    <script> #}
    {#        const cancelPath = "{{ path('hike_cancel') }}" #}
    {#    </script> #}
{% endblock %}

{% block title %}
    {{ parent() }} | Hike Details
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    {# Leaflet #}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    {# code of map #}
    {% if hike.location.latitude and hike.location.longitude %}
        <script>

            const lat = {{ hike.location.latitude }};
            const lng = {{ hike.location.longitude }};


            const locationName = "{{ hike.location.name | e('js') }}";


            const map = L.map('map').setView([lat, lng], 13);




            const streets = L.tileLayer(
                'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
                { attribution: '© <a href="https://www.openstreetmap.org/">OpenStreetMap</a> contributors' }
            );

            // Esri
            const satellite = L.tileLayer(
                'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
                { attribution: '© Esri' }
            );

            // OpenTopoMap
            const terrain = L.tileLayer(
                'https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png',
                { attribution: '© <a href="https://opentopomap.org/">OpenTopoMap</a> contributors' }
            );


            streets.addTo(map);
            let currentLayer = streets;



            function setLayer(type, btn) {

                map.removeLayer(currentLayer);


                if (type === 'streets')   currentLayer = streets;
                if (type === 'satellite') currentLayer = satellite;
                if (type === 'terrain')   currentLayer = terrain;


                currentLayer.addTo(map);


                document.querySelectorAll('.map-controls button').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            }

            // add marker to the map

            L.marker([lat, lng])
                .addTo(map)
                .bindPopup('<strong>📍 Point de départ</strong><br>' + locationName)
                .openPopup();
        </script>
    {% endif %}
{% endblock %}

