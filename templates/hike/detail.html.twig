{% extends 'base.html.twig' %}

{#+++++++++++++++ BLOCK MAP +++++++++++++++++#}

{% block stylesheets %}
    {{ parent() }}
    <link
        rel="stylesheet"
        href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    />
    <style>
        /* Стили карты и кнопок переключения */
        #map {
            height: 420px;
            width: 100%;
            border-radius: 8px;
            margin-top: 1rem;
        }
        .map-controls {
            display: flex;
            gap: 8px;
            margin-bottom: 8px;
            flex-wrap: wrap;
        }
        .map-controls button {
            padding: 6px 14px;
            border: 2px solid #ccc;
            border-radius: 6px;
            background: white;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.2s;
        }
        .map-controls button:hover {
            border-color: #4a7c59;
            background: #f0f7f2;
        }
        .map-controls button.active {
            border-color: #4a7c59;
            background: #4a7c59;
            color: white;
        }
    </style>
{% endblock %}


{% block body %}

    <div class="container-details">

        <div class="details">

            <div class="details-row d-row1">

                <div class="details-container-img"><img src="{{ asset('images/hikes/' ~ hike.picture ) }}" class="details-img" alt="Image de la randonnée"></div>

                <div class="details-container-map"><img src="{{ asset('images/hikes/' ~ hike.picture ) }}" class="details-map"></div>

            </div>

            <div class="details-row details-zone-infos">

                <div class="details-col">

                    <h2 class="details-title">{{ hike.name }}</h2>

                    <div class="details-statut">{{ hike.status.label }}</div>

                    <div class="details-date">{{ hike.dateEvent | date ('d-m-Y') }}</div>

                    <div class="details-date-subscription">{{ hike.dateSubscription | date ('d-m-Y') }}</div>

                    <div class="details-duration">{{ durationString }}</div>

                    <div class="details-difficulty">{{ hike.difficulty.label }}</div>

                    <div class="details-description">{{ hike.description }}</div>

                    <div class="details-campus">{{ hike.campus.name }}</div>

                    <button>Modifier</button>
                    <button>Annuler la randonnée</button>

                </div>


                <div class="details-col">

                    <div class="details-label">Adresse</div>
                    <div class="details-location">
                        {{ hike.location.name }}</div>

                    <div class="details-adress">
                        {{ hike.location.address }} </div>

                    <div class="details-label">Organisateur</div>
                    <div class="details-container-planner">
                        <div class="detail-user-container">

                            {% if hike.planner %}
                                <img src="{{ asset('images/profilePictures/' ~ hike.planner.picture) }}" class="user-pp">
                                <div class="tooltip">{{ hike.planner.username }}</div>
                            {% else %}
                                Utilisateur supprimé
                            {% endif %}

                        </div>
                    </div>

                    <div class="details-label">Participants : {{ hike.participant|length }} / {{ hike.nbMaxSubscription }}</div>
                    <div class="details-container-participants">

                        {% for participant in hike.participant %}


                            <a
                            href="{{ path('app_profile', {'id': participant.id}) }}"><img
                                src="{{ asset('images/profilePictures/' ~ participant.picture) }}"
                                alt="{{ participant.username }}" class="user-pp"></a>
                            <div class="tooltip">{{ participant.username }}</div>

                        {% endfor %}

