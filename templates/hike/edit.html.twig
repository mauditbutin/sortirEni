{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} | Modifier votre randonnée
{% endblock %}

{% block body %}

    <h2>Modifier votre randonnée</h2>

    {{  form_start(hikeForm, {'attr' : {'id' : 'hikeCreateForm'}}) }}
    {{ form_row(hikeForm.name, {label: 'Nom'}) }}
    {{ form_row(hikeForm.dateEvent, {label: 'Date et heure de l\'évènement'}) }}
    {{ form_row(hikeForm.dateSubscription, {label: 'Date limite d\'inscription'}) }}
    {{ form_row(hikeForm.nbMaxSubscription, {label: 'Nombre de places'}) }}
    {{ form_row(hikeForm.difficulty, {label: 'Sélectionnez un niveau'}) }}
    {{ form_row(hikeForm.duration, {label: 'Durée (en minutes)'}) }}
    {{ form_row(hikeForm.description, {label: 'Description et infos'}) }}
    {{ form_row(hikeForm.picture, {label: 'Ajouter une photo'}) }}
    {{ form_row(hikeForm.city, {label: 'Choisir une ville'}) }}
    {{ form_row(hikeForm.location, {label: 'Choisir un lieu'}) }}
    <a href="#modaleFormLocation" id="buttonOpenLocationModale">Ajouter un lieu</a>
    <fieldset>
        <div>Adresse : <span id="adressLocationHikeCreate"></span></div>
        <div>Code Postal : <span id="zipLocationHikeCreate"></span></div>
        <div>Ville : <span id="cityLocationHikeCreate"></span></div>
    </fieldset>
    {{ form_row(hikeForm.campus, {label: 'Campus'}) }}
    <button type="submit">Valider les modifications</button>
    <a href="{{ path('hike_detail', {'id': hike.id}) }}">Annuler</a>
    {{  form_end(hikeForm) }}


    <div id="modaleFormLocation" class="modale">
        <a href="#" class="modaleOverlay" id="modaleLocationOverlay"></a>
        <div class="modaleContent">
            <h2>Ajouter un lieu</h2>

            {{  form_start(locationForm, {'attr' : {'id': 'locationCreateForm'}}) }}
            {{ form_row(locationForm.name, {label: 'Nom du lieu'}) }}
            {{ form_row(locationForm.address, {label: 'Adresse'}) }}
            {{ form_row(locationForm.zipcode, {label: 'Code Postal'}) }}
            {{ form_row(locationForm.city, {label: 'Ville'}) }}
            {{ form_row(locationForm.latitude, {label: 'Latitude'}) }}
            {{ form_row(locationForm.longitude, {label: 'Longitude'}) }}
            <button type="submit">Ajouter le lieu</button>
            <a href="#" id="buttonCloseLocationModale">Annuler</a>
            {{ form_end(locationForm) }}

        </div>
    </div>

    <script>
        const locationAjaxPath = "{{ path('api_location_addAjax') }}"
        const getLocationsByCity = "{{ path('api_location_getLocationsByCity') }}"
        const getLocationInfo = '{{ path('api_location_getInfos') }}'
    </script>


{% endblock %}

