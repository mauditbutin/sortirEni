{% extends 'base.html.twig' %}

{% block title %}Admin{% endblock %}

{% block body %}


<h2 class="admin_h2">Espace Administrateur</h2>

<div class="admin_container">
    {# Les boutons pour l'affichage #}

    <a href="#tabUser">
        <button id="admin_btn_tabUser" class="admin_btnOnglet admin_clickedBtn"> Gestion des utilisateurs</button>
    </a>

    <a href="#tabRando">
        <button id="admin_btn_tabRando" class="admin_btnOnglet"> Gestion des randonnées</button>
    </a>

    <a href="#tabCampus">
        <button id="admin_btn_tabCampus" class="admin_btnOnglet"> Gestion des Campus</button>
    </a>

    <a href="#tabVille">
        <button id="admin_btn_tabVille" class="admin_btnOnglet"> Gestion des Villes</button>
    </a>

    {# ----------------------------------------------------- #}


    {# Affichage des données #}
</div>

<div class="admin_onglets">

    {# Onglet gestion des utilisateurs #}
    <div id="tabUser" class="admin_tab {% if activeTab == 'tabUser' %}active{% endif %}">
        <div class="admin_btnAddUser_Container">
            <a href="{{ path('admin_formUser') }}">
                <button>Ajouter un utilisateur</button>
            </a>
            <a href="{{ path('admin_uploadcsv') }}">
                <button>Importer un fichier csv</button>
            </a>

        </div>
        <div class="admin_tableau">
            <table>
                <thead>
                <tr class="admin_tableauThead">
                    <th scope="col" class="admin_tableHeader" style="width: 11%">Picture</th>
                    <th scope="col" class="admin_tableHeader" style="width: 10%">Pseudo</th>
                    <th scope="col" class="admin_tableHeader" style="width: 8%">prénom</th>
                    <th scope="col" class="admin_tableHeader" style="width: 8%">nom</th>
                    <th scope="col" class="admin_tableHeader" style="width: 18%">email</th>
                    <th scope="col" class="admin_tableHeader" style="width: 13%">campus</th>
                    <th scope="col" class="admin_tableHeader" style="width: 7%">statut</th>
                    <th scope="col" class="admin_tableHeader" style="width: 25%">actions</th>
                </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr class="{% if loop.index is odd %}admin_odd{% endif %}">
                        <th scope="row">
                            <a href="{{ path('app_profile', {'id' : user.id}) }}">
                                <img class="admin_imgProfil"
                                     src="{{ asset('images/profilePictures/' ~ user.picture) }}"
                                     alt="{{ user.username }}"></a>
                        </th>
                        <td>
                            <a class="admin_username" href="{{ path('app_profile', {'id' : user.id}) }}">
                                {{ user.username }}
                            </a>
                        </td>
                        <td>
                            {{ user.firstname }}
                        </td>
                        <td>
                            {{ user.lastname }}
                        </td>
                        <td>
                            {{ user.email }}
                        </td>
                        <td>
                            {{ user.campus.name }}
                        </td>

                        {# ===== Satuts===== #}
                        <td>
                            {% if user.active %}
                                <div class="admin_activeSign">
                                    <p>Active</p>
                                </div>
                            {% else %}
                                <div class="admin_inctiveSign">
                                    <p>Inactive</p>
                                </div>
                            {% endif %}
                        </td>

                        {# ======= Bouton Deactivate / Activate /delete / randonnées ======== #}
                        <td>
                            <div class="admin_UserAction">
                                {% if user.active %}
                                    <a class="admin_link" href="{{ path('admin_deactivate_user', {id: user.id}) }}">
                                        <button class="admin_deactiveStatus"
                                                onclick="return confirm('Disable {{ user.firstname }} {{ user.lastname }} ?\nHe will be removed from all his hikes.');">
                                            Disable
                                        </button>
                                    </a>
                                {% else %}
                                    <a href="{{ path('admin_activate_user', {id: user.id}) }}"
                                       onclick="return confirm('Reactivation account of {{ user.firstname }} {{ user.lastname }} ?');">
                                        <button class="admin_reactiveStatus">Reactivate</button>
                                    </a>
                                {% endif %}

                                {% if app.user != user %}
                                    <a href="{{ path('admin_delete_user', {id: user.id}) }}"
                                       onclick="return confirm('Delete {{ user.firstname }} {{ user.lastname }} permanently ?');">
                                        <button class="admin_btnDeleteUser">
                                            Delete
                                        </button>
                                    </a>
                                {% endif %}

                                {% if user.active %}
                                    <button class="admin_BtnInfosUserRando"
                                            data-user-id="{{ user.id }}">{# data-user-id permet de cibler uniquement l'utilisateur de cette itération de la boucle for générale #}
                                        Hikes
                                    </button>
                                {% endif %}

                            </div>

                        </td>
                    </tr>
                    <tr class="admin_sectionRando admin_InfoHide {% if loop.index is odd %}admin_odd{% endif %}"
                        data-user-id="{{ user.id }}">
                        {% if user.plannedHikes | length > 0 %}
                            <td colspan="8">
                                <hr class="admin_hr">
                            </td>
                        {% endif %}
                    </tr>
                    <tr class="admin_sectionRando admin_InfoHide {% if loop.index is odd %}admin_odd{% endif %}"
                        data-user-id="{{ user.id }}">{# data-user-id permet de cibler uniquement l'utilisateur de cette itération de la boucle for générale #}
                        {% if user.plannedHikes | length > 0 %}
                            <td colspan="3">
                                <p class="admin_hikeTitre">Randonnées organisées :</p>
                            </td>
                            <td colspan="5">
                                <div class="admin_linkHike">
                                    {% for hike in user.plannedHikes %}

                                        {% if hike.id is not null %}
                                            <a href="{{ path('hike_detail', {'id' : hike.id}) }}">
                                                {{ hike.name }} ;
                                            </a>
                                        {% endif %}

                                    {% endfor %}
                                </div>
                            </td>
                        {% endif %}
                    </tr>
                    <tr class="admin_sectionRando admin_InfoHide {% if loop.index is odd %}admin_odd{% endif %}"
                        data-user-id="{{ user.id }}">
                        {% if user.participatedHikes | length > 0 %}
                            <td colspan="3">
                                <p>Inscription aux randonnées :</p>
                            </td>
                            <td colspan="5">
                                <div class="admin_linkHike">
                                    {% for hike in user.participatedHikes %}

                                        {% if hike.id is not null %}
                                            <a href="{{ path('hike_detail', {'id' : hike.id}) }}">
                                                {{ hike.name }} ;
                                            </a>
                                        {% endif %}

                                    {% endfor %}
                                </div>

                            </td>
                        {% endif %}
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>


    {# ----------------------------------------------------- #}
    {# Onglet gestion des Randonnées #}


    <div id="tabRando" class="admin_tab {% if activeTab == 'tabRando' %}active{% endif %}">
        <div class="admin_tableau">
            <table>
                <thead>
                <tr class="admin_tableauThead">
                    <th scope="col" class="admin_tableHeader">Picture</th>
                    <th scope="col" class="admin_tableHeader">Nom de la randonnée</th>
                    <th scope="col" class="admin_tableHeader">Organisateur</th>
                    <th scope="col" class="admin_tableHeader">Date de la randonnée</th>
                    <th scope="col" class="admin_tableHeader">Statut</th>
                    <th scope="col" class="admin_tableHeader">Action</th>
                </tr>
                </thead>
                <tbody>
                {% for hike in hikes %}
                    <tr class="{% if loop.index is odd %}admin_odd{% endif %}">
                        <th>
                            {% if hike.planner %}
                                <a href="{{ path('hike_detail', {'id' : hike.id}) }}">
                                    <img class="admin_imgHike" src="{{ asset('images/hikes/' ~ hike.picture ) }}"
                                         alt="{{ hike.name }}">
                                </a>
                            {% endif %}
                        </th>
                        <td>
                            <a class="admin_linkHike" href="{{ path('hike_detail', {'id' : hike.id}) }}">
                                {{ hike.name }}
                            </a>
                        </td>
                        <td class="admin_username">
                            {% if hike.planner %}
                                <a class="admin_username"
                                   href="{{ path('app_profile', {'id' : hike.planner.id}) }}">
                                    {{ hike.planner.username }}
                                </a>
                            {% else %} <p class="admin_username"> utilisateur supprimé</p>
                            {% endif %}
                        </td>
                        <td>
                            {{ hike.dateEvent | format_date(pattern="d MMMM yyyy", locale="fr") }}
                        </td>
                        <td>
                            {{ hike.status.label }}
                        </td>
                        <td>
                            {% if hike.status.label != 'Annulée' and hike.status.label !='Archivée' and hike.status.label !='Passée' %}
                                <a href="{{ path('admin_cancelHike', {'id': hike.id}) }}"
                                   onclick="return confirm('Etes vous sûr de vouloir annuler cette randonnée ?');">
                                    <button class="admin_deactiveStatus"> Annuler</button>
                                </a>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# ----------------------------------------------------- #}
    {# Onglet gestion des campus #}
    <div id="tabCampus" class="admin_tab {% if activeTab == 'tabCampus' %}active{% endif %}">

        <div class="admin_btnAddUser_Container">
            <a href="{{ path('admin_addCampus') }}">
                <button>Ajouter un campus</button>
            </a>


        </div>
        <div class="admin_tableau">
            <table>
                <thead>
                <tr class="admin_tableauThead">
                    <th scope="col" class="admin_tableHeader">Nom</th>
                    <th scope="col" class="admin_tableHeader">Randonnées de ce campus</th>
                    <th scope="col" class="admin_tableHeader">Elves de ce campus</th>
                </tr>
                </thead>
                <tbody>
                {% for element in campus %}
                    <tr class="{% if loop.index is odd %}admin_odd{% endif %}">
                        <td>{{ element.name }}</td>
                        <td class="admin_HikeCampus">{% for hike in element.hikes %}
                                {% if hike.id is not null %}
                                    <a href="{{ path('hike_detail', {'id' : hike.id}) }}">
                                        {{ hike.name }}<br>
                                    </a>
                                {% endif %}
                            {% endfor %}</td>
                        <td>{% for eleve in element.users %}
                                {% if eleve.id is not null %}
                                    {{ eleve.username }}
                                {% endif %}
                            {% endfor %}</td>

                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>


    </div>

    {# ----------------------------------------------------- #}
    {# Onglet gestion des villes #}
    <div id="tabVille" class="admin_tab {% if activeTab == 'tabVille' %}active{% endif %}">

        <div class="admin_btnAddUser_Container">
            <a href="{{ path('admin_addCity') }}">
                <button>Ajouter une ville</button>
            </a><br>
        </div>

        <div class="admin_tableau">
            <table>
                <thead>
                <tr class="admin_tableauThead">
                    <th scope="col" class="admin_tableHeader">Nom</th>
                    <th scope="col" class="admin_tableHeader">Code postal</th>
                    <th scope="col" class="admin_tableHeader">Emplacements liés</th>
                </tr>
                </thead>
                <tbody>
                {% for ville in villes %}
                <tr class="{% if loop.index is odd %}admin_odd{% endif %}">
                    <td>{{ ville.name }}</td>
                    <td>{{ ville.zipcode }}</td>
                    <td class="admin_villes">{% for location in ville.locations %}
                            {{ location.name }}<br>
                        {% endfor %}</td>
                    {% endfor %}
                </tbody>
            </table>

        </div>
    </div>

    {% endblock %}
