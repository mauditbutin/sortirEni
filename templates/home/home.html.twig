{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">


        {% for hike in hikes %}
            <div>
                <div>
                    <img
                        src="{{ asset('images/logoSite/conception-modele-logo-montagne-minimaliste_698780-847.avif') }}"
                        alt="{{ hike.name }}" style="width: 10rem">
                </div>
                <div>
                    nom : {{ hike.name }}
                    <br>
                    description : {{ hike.description }}
                    <br>
                    organisateur : {{ hike.planner.username }}
                    <br>
                    date de l'évènement : {{ hike.dateEvent | date ('d-m-Y') }}
                </div>
                <br>

            </div>
        {% endfor %}

    </div>
{% endblock %}
